# pnpm config — read at install time on every runner.
#
# `supported-architectures[*]` tells pnpm to install optional native binaries
# for the listed platforms regardless of the current machine. This is the
# fix for vitest 4 / rolldown 1.0.0-rc.17 / pnpm 10.22 + frozen lockfile +
# Linux CI runners: a macOS-authored lockfile must carry both darwin-arm64
# and linux-x64-gnu @rolldown/binding-* symlinks, and `--frozen-lockfile`
# on Linux must end up linking @rolldown/binding-linux-x64-gnu into the
# rolldown package or vitest crashes at startup with "Cannot find native
# binding".
#
# Settings live in BOTH pnpm-workspace.yaml AND here. .npmrc is the
# canonical place pnpm consults across all install code paths; the
# workspace file mirrors it for IDE / pnpm-cli visibility. If only one of
# these existed, frozen-lockfile install on Linux skipped the linux
# binding (observed empirically on PR #1 CI runs 24921178663 + 24921274827).

supported-architectures[os][]=darwin
supported-architectures[os][]=linux
supported-architectures[cpu][]=x64
supported-architectures[cpu][]=arm64
supported-architectures[libc][]=glibc
supported-architectures[libc][]=musl
