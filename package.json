{
  "name": "ndi-cloud-app",
  "version": "0.0.0",
  "private": true,
  "description": "Unified NDI Cloud monorepo: marketing + data browser on Next.js 15 App Router",
  "packageManager": "pnpm@10.22.0",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm -C apps/web dev",
    "build": "pnpm -C apps/web build",
    "start": "pnpm -C apps/web start",
    "lint": "pnpm -C apps/web lint",
    "typecheck": "pnpm -C apps/web typecheck",
    "test": "pnpm -C apps/web test",
    "test:watch": "pnpm -C apps/web test:watch",
    "test:coverage": "pnpm -C apps/web test:coverage",
    "test:e2e": "pnpm -C apps/web test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md,css}\"",
    "hygiene": "node scripts/find-finder-dups.mjs",
    "bundle-size": "node scripts/check-bundle-size.mjs"
  },
  "devDependencies": {
    "prettier": "3.8.0"
  },
  "pnpm": {
    "overrides": {
      "postcss@<8.5.10": ">=8.5.10"
    },
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  }
}
